# AI Novel Generator - Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Application Settings
# ===================
APP_NAME=AI Novel Generator
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# ===================
# JWT Authentication
# ===================
# IMPORTANT: Change this to a secure random string in production
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===================
# MySQL Database
# ===================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=ai_novel_generator

# ===================
# Milvus Vector Database
# ===================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# ===================
# Neo4j Graph Database
# ===================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ===================
# AI Model Configuration (Default)
# ===================
# OpenAI API (or compatible API)
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gemini-3-pro-preview

# Custom Model (Optional)
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_API_BASE=
CUSTOM_MODEL_NAME=

# ===================
# Generation Parameters
# ===================
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=0.9
DEFAULT_MAX_TOKENS=4096
